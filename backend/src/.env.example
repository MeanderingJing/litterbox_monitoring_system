# Logging
LOG_LEVEL=INFO          # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_TO_FILE=true        # true/false
LOG_DIR=logs
LOG_FILE_NAME=litterbox_sync_YYYYMMDD.log

# Database
DATABASE_USER=example_user
DATABASE_PASSWORD=example_password
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=example_db
DATABASE_URL=postgresql://${DATABASE_USER}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_NAME}

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=user
RABBITMQ_PASSWORD=password
RABBITMQ_VHOST=/

RABBITMQ_CONNECT_RETRIES=5
RABBITMQ_CONNECT_RETRY_DELAY=5

# Data Persister
BATCH_SIZE=10
BATCH_TIMEOUT=30
PREFETCH_COUNT=50

# Flask / JWT
JWT_SECRET_KEY=change_me_in_production

# Flask CLI (for `flask run`). Defaults: port 5000, host 127.0.0.1
FLASK_RUN_PORT=8000
FLASK_RUN_HOST=0.0.0.0